{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "playwright.config.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "test-data/**/*.ts",
    "fixtures/**/*.ts",
    "utils/**/*.ts"
  ]
}
